<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mwh.mapper.UserMapper">
    <resultMap id="selectUserVo" type="com.mwh.vo.UserVo">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="realName" column="real_name"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="facePhotoUrl" column="face_photo_url"/>
        <result property="hireDate" column="hire_date"/>
    </resultMap>
    <select id="selectAllPeople" resultMap="selectUserVo">
        select id,username,role,status,real_name,email,phone,face_photo_url,hire_date from user
        <where>
            <if test="userPageDTO.status != null">
                and status = #{userPageDTO.status}
            </if>
            <if test="userPageDTO.role != null">
                and role = #{userPageDTO.role}
            </if>
            <if test="userPageDTO.realname != null">
                and real_name like concat('%',#{userPageDTO.realname},'%')
            </if>
            <if test="userPageDTO.phonenumber != null">
                and phone like concat('%',#{userPageDTO.phonenumber},'%')
            </if>
        </where>
    </select>
</mapper>
